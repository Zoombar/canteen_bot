# Telegram
BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs for admins
ADMIN_IDS=123456789

# Canteen worker chat: user id (DM) or group id (negative for supergroups)
CANTEEN_CHAT_ID=-1001234567890

# Таймзона фиксирована на сервере: Asia/Omsk

# Рассылка меню в будни (локальное время суток)
MENU_BROADCAST_TIME=08:30

# Дедлайн заказа в тот же день (локальное время суток).
# После дедлайна IMAP не опрашивается до «за час до» MENU_BROADCAST_TIME следующего буднего дня.
ORDER_DEADLINE_TIME=11:00

# Напоминание в Telegram тем, кто не оформил заказ: за сколько минут до ORDER_DEADLINE_TIME (будни). 0 — отключить.
ORDER_REMINDER_BEFORE_DEADLINE_MINUTES=20

# Напоминание тем, у кого в корзине есть блюда, но заказ не подтверждён: за сколько минут до дедлайна (будни). 0 — отключить.
ORDER_DRAFT_CART_REMINDER_BEFORE_DEADLINE_MINUTES=10

# Тестовый режим: true — заказы в выходные + в любое время суток (без дедлайна)
TEST_MODE=false

# IMAP (optional — if unset, only manual menu upload works)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=secret
# Optional: filter sender contains (substring)
IMAP_SENDER_FILTER=
# Optional: only fetch unseen
IMAP_ONLY_UNSEEN=true
# Будни: пока меню на сегодня не загружено, после этого времени (Омск) почта опрашивается каждые 3 мин;
# до этого — раз в 15 мин. Поставьте 00:00 чтобы при отсутствии меню всегда опрашивать каждые 3 мин.
IMAP_URGENT_AFTER=10:00
