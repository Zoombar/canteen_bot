# Telegram
BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs for admins
ADMIN_IDS=123456789

# Canteen worker chat: user id (DM) or group id (negative for supergroups)
CANTEEN_CHAT_ID=-1001234567890

# Timezone (menu broadcast & deadlines)
TZ=Asia/Omsk

# Weekday menu broadcast (24h local time)
MENU_BROADCAST_TIME=08:30

# Order deadline same day (24h local time)
ORDER_DEADLINE_TIME=11:00

# IMAP (optional — if unset, only manual menu upload works)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASSWORD=secret
# Optional: filter sender contains (substring)
IMAP_SENDER_FILTER=
# Optional: only fetch unseen
IMAP_ONLY_UNSEEN=true
